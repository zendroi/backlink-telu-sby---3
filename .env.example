DATABASE_URL="file:./dev.db"

# Search provider. This implementation uses Serper by default.
SERPER_API_KEY=""
SEARCH_RESULTS_LIMIT=8
SEARCH_RESULTS_PER_QUERY=10
SEARCH_MAX_CHECKS=40
SEARCH_MATCH_TARGET=15
SEARCH_CONCURRENCY=5
PAGE_INSPECTION_TIMEOUT_MS=8000
PAGE_MAX_BYTES=5000000

# OpenAI
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4.1-mini"

# Optional fallback provider
GROQ_API_KEY=""
GROQ_MODEL="llama-3.1-8b-instant"

# App defaults
DEFAULT_USER_EMAIL="local@example.com"
NEXT_PUBLIC_APP_NAME="AI Backlink Assistant"
