generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int             @id @default(autoincrement())
  email     String          @unique
  name      String?
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  projects  SearchProject[]
}

model SearchProject {
  id                 Int                @id @default(autoincrement())
  userId             Int
  keyword            String
  targetDomain       String
  userWebsiteUrl     String
  userWebsiteTitle   String?
  userWebsiteSummary String?
  status             String             @default("active")
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  user               User               @relation(fields: [userId], references: [id])
  candidates         CandidateWebsite[]
  articles           TelkomArticle[]
  searchJobs         SearchJob[]
}

model SearchJob {
  id            String        @id
  projectId     Int
  status        String        @default("queued")
  progress      Int           @default(0)
  message       String        @default("")
  totalFound    Int           @default(0)
  checkedCount  Int           @default(0)
  matchedCount  Int           @default(0)
  rejectedCount Int           @default(0)
  maxChecks     Int           @default(100)
  matchTarget   Int           @default(40)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  project       SearchProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model CandidateWebsite {
  id               Int                @id @default(autoincrement())
  projectId        Int
  title            String
  url              String
  domain           String
  hasCommentForm   Boolean            @default(false)
  hasWebsiteField  Boolean            @default(false)
  status           String             @default("belum dicek")
  notes            String?
  searchQuery      String?
  snippet          String?
  inspectionStatus String             @default("pending")
  relevanceScore   Int                @default(0)
  inspectionReason String?
  inspectedAt      DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  project          SearchProject      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  comments         GeneratedComment[]

  @@unique([projectId, url])
}

model TelkomArticle {
  id              Int                @id @default(autoincrement())
  projectId       Int
  title           String
  url             String
  summary         String
  relevanceReason String
  relevanceScore  Int                @default(0)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  project         SearchProject      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  comments        GeneratedComment[]

  @@unique([projectId, url])
}

model GeneratedComment {
  id                  Int              @id @default(autoincrement())
  candidateWebsiteId  Int
  telkomArticleId     Int?
  generatedComment    String
  suggestedAnchorText String
  ethicalNote         String
  provider            String           @default("unknown")
  createdAt           DateTime         @default(now())
  candidateWebsite    CandidateWebsite @relation(fields: [candidateWebsiteId], references: [id], onDelete: Cascade)
  telkomArticle       TelkomArticle?   @relation(fields: [telkomArticleId], references: [id], onDelete: SetNull)
}
